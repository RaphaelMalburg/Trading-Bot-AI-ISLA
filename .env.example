# .env.example
# Template for the environment variables required to run the bot.
# NEVER commit your real .env file.

# ==========================================
# 1. Alpaca API (for market data + order execution)
#    Sign up at https://alpaca.markets/
# ==========================================
ALPACA_API_KEY="YOUR_ALPACA_API_KEY"
ALPACA_SECRET_KEY="YOUR_ALPACA_SECRET_KEY"

# Optional: Alpaca endpoint (defaults to paper)
# ALPACA_URL="https://paper-api.alpaca.markets"

# ==========================================
# 2. OpenRouter API (for LLM-based sentiment analysis)
#    Sign up at https://openrouter.ai/
# ==========================================
OPENROUTER_API_KEY="sk-or-v1-YOUR_OPENROUTER_KEY"
# Optional overrides:
# OPENROUTER_MODEL="google/gemini-2.5-flash-lite"
# OPENROUTER_URL="https://openrouter.ai/api/v1/chat/completions"

# ==========================================
# 3. Strategy tunables (all optional — sensible defaults baked in)
# ==========================================
# CONFIDENCE_THRESHOLD=0.55     # Min RF confidence to enter a trade
# SENTIMENT_FLOOR=-0.5          # Veto if Gemini sentiment falls below this
# SL_ATR_MULT=1.0               # Stop-loss distance: entry - ATR * SL_ATR_MULT
# TP_ATR_MULT=2.0               # Take-profit distance: entry + ATR * TP_ATR_MULT
# SL_LIMIT_SLIPPAGE=0.005       # Slack below stop_price for stop-limit fill
# MAX_RISK_PER_TRADE=0.05       # Max capital fraction at risk per trade
# FILL_POLL_ATTEMPTS=10         # Retries waiting for BUY fill
# FILL_POLL_INTERVAL_S=1.0      # Seconds between fill polls
# TP_WATCHDOG_INTERVAL_S=60     # How often the soft-TP watcher runs

# Optional model paths (advanced)
# MODEL_PATH=models/rf_model.pkl
# FEATURES_PATH=models/model_features.pkl
