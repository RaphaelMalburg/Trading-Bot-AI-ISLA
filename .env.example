# .env.example
# Este arquivo serve como um modelo (template) para as chaves de API necessárias para rodar o Bot.
# NUNCA comite o seu arquivo '.env' real para o GitHub.

# ==========================================
# 1. ALPACA API (Para obter dados OHLCV e enviar ordens)
# Crie uma conta gratuita em: https://alpaca.markets/
# ==========================================
ALPACA_API_KEY="COLOQUE_SUA_API_KEY_AQUI"
ALPACA_SECRET_KEY="COLOQUE_SUA_SECRET_KEY_AQUI"

# Escolha o endpoint correto dependendo do ambiente
# Para Paper Trading (Simulação com dinheiro falso):
ALPACA_URL="https://paper-api.alpaca.markets"
# Para Live Trading (Dinheiro Real):
# ALPACA_URL="https://api.alpaca.markets"

# ==========================================
# 2. OPENROUTER API (Para Análise de Sentimento com LLM)
# Crie uma conta em: https://openrouter.ai/
# ==========================================
OPENROUTER_API_KEY="sk-or-v1-COLOQUE_SUA_CHAVE_DO_OPENROUTER_AQUI"
